{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/parent/:path*",
      "destination": "/parent/index.html"
    },
    {
      "source": "/school/:path*",
      "destination": "/school/index.html"
    },
    {
      "source": "/((?!parent|school|assets|css|img|js|api).*)/?",
      "destination": "/$1.html"
    }
  ]
}
